<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme -->
    <style name="Theme.CDDALauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/accent_green_pressed</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/accent_green_dim</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="colorError">@color/color_error</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- PRIMARY button: full green, dark text -->
    <style name="Widget.CDDALauncher.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_green</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="rippleColor">@color/accent_green_pressed</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- SECONDARY button: outlined dark card -->
    <style name="Widget.CDDALauncher.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/bg_card</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- GHOST button: text only, green border -->
    <style name="Widget.CDDALauncher.Button.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent_green_dim</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="elevation">0dp</item>
    </style>

</resources>
