<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme - FULLSCREEN -->
    <style name="Theme.CDDALauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/accent_green_dim</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.CDDALauncher.Overlay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- ============================================ -->
    <!-- STYLES FOR MAIN ACTIVITY & CONTROLS ACTIVITY -->
    <!-- ============================================ -->

    <!-- Primary Button -->
    <style name="Widget.CDDALauncher.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#CC22C55E</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Secondary Button -->
    <style name="Widget.CDDALauncher.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">#CC0D0F0B</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Ghost Button -->
    <style name="Widget.CDDALauncher.Button.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent_green_dim</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">#AA0D0F0B</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ============================================ -->
    <!-- STYLES FOR OVERLAY (Floating Controls)       -->
    <!-- ============================================ -->

    <!-- Overlay Primary Button -->
    <style name="Widget.CDDALauncher.Overlay.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#CC22C55E</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Overlay Ghost Button -->
    <style name="Widget.CDDALauncher.Overlay.Button.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent_green_dim</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">#AA0D0F0B</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Overlay Base Button -->
    <style name="Widget.CDDALauncher.Overlay.Button" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">#CC0D0F0B</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
