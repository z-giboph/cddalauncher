<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- OVERLAY base button: semi-transparent dark, green border -->
    <style name="Widget.CDDALauncher.Overlay.Button" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">#CC0D0F0B</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- OVERLAY primary: confirm/action button -->
    <style name="Widget.CDDALauncher.Overlay.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#CC22C55E</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- OVERLAY ghost: hotbar buttons -->
    <style name="Widget.CDDALauncher.Overlay.Button.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent_green_dim</item>
        <item name="android:fontFamily">monospace</item>
        <item name="strokeColor">@color/accent_green_dim</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">#AA0D0F0B</item>
        <item name="cornerRadius">4dp</item>
        <item name="rippleColor">@color/accent_green_dim</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
