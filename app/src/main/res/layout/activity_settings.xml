<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0F0B"
    android:padding="16dp">

    <TextView
        android:id="@+id/version_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ SETTINGS"
        android:textColor="#22C55E"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#1A1A1A"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Overlay Controls"
            android:textColor="#E8EDE5"
            android:textSize="16sp"
            android:fontFamily="monospace"/>

        <Switch
            android:id="@+id/switch_overlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#1A1A1A"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fullscreen Mode"
            android:textColor="#E8EDE5"
            android:textSize="16sp"
            android:fontFamily="monospace"/>

        <Switch
            android:id="@+id/switch_fullscreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#1A1A1A"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lock Landscape"
            android:textColor="#E8EDE5"
            android:textSize="16sp"
            android:fontFamily="monospace"/>

        <Switch
            android:id="@+id/switch_landscape"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_clear_cache"
        style="@style/Widget.CDDALauncher.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑️ Clear Cache"
        android:textSize="16sp"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_back"
        style="@style/Widget.CDDALauncher.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BACK"
        android:textSize="18sp"
        android:padding="12dp"/>

</LinearLayout>