<?xml version="1.0" encoding="utf-8"?>
<GridLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="4dp"
    android:background="@drawable/overlay_panel_bg"
    app:columnCount="2"
    app:rowCount="3">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayBtnConfirm"
        style="@style/Widget.CDDALauncher.Overlay.Button.Primary"
        android:layout_width="60dp"
        android:layout_height="52dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        android:text="✓"
        android:textSize="20sp"
        app:layout_columnWeight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayBtnCancel"
        style="@style/Widget.CDDALauncher.Overlay.Button"
        android:layout_width="60dp"
        android:layout_height="52dp"
        android:layout_marginBottom="4dp"
        android:text="✕"
        android:textSize="18sp"
        app:layout_columnWeight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayBtnInventory"
        style="@style/Widget.CDDALauncher.Overlay.Button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        android:text="BAG"
        android:textSize="10sp"
        android:fontFamily="monospace"
        app:layout_columnWeight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayBtnPickup"
        style="@style/Widget.CDDALauncher.Overlay.Button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:layout_marginBottom="4dp"
        android:text="GET"
        android:textSize="10sp"
        android:fontFamily="monospace"
        app:layout_columnWeight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayBtnDrop"
        style="@style/Widget.CDDALauncher.Overlay.Button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:layout_marginEnd="4dp"
        android:text="DROP"
        android:textSize="10sp"
        android:fontFamily="monospace"
        app:layout_columnWeight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayBtnWait"
        style="@style/Widget.CDDALauncher.Overlay.Button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:text="WAIT"
        android:textSize="10sp"
        android:fontFamily="monospace"
        app:layout_columnWeight="1" />

</GridLayout>
