<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_noise"
    android:padding="16dp">

    <TextView
        android:id="@+id/game_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CDDA LAUNCHER"
        android:textColor="@color/accent_green"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btn_launch_game"
        style="@style/Widget.CDDALauncher.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LAUNCH CDDA"
        android:textSize="24sp"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_controls"
        style="@style/Widget.CDDALauncher.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CONTROLS"
        android:textSize="18sp"
        android:padding="12dp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_settings"
        style="@style/Widget.CDDALauncher.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SETTINGS"
        android:textSize="18sp"
        android:padding="12dp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_mods"
        style="@style/Widget.CDDALauncher.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MODS"
        android:textSize="18sp"
        android:padding="12dp"/>

</LinearLayout>