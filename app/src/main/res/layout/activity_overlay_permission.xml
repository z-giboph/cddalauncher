<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0D0F0B"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔓 OVERLAY PERMISSION"
        android:textColor="#22C55E"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This app needs overlay permission to show controls on top of CDDA."
        android:textColor="#88997A"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_request_permission"
        style="@style/Widget.CDDALauncher.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GRANT PERMISSION"
        android:textSize="18sp"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_start_overlay"
        style="@style/Widget.CDDALauncher.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="START OVERLAY"
        android:textSize="18sp"
        android:padding="16dp"/>

</LinearLayout>